      <description>&lt;p&gt;摘要&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;&lt;a href=&#34;#%E4%B8%80%E3%80%81%E5%AE%9A%E4%B9%89%E5%92%8C%E6%95%B0%E6%8D%AE%E7%BB%93%E6%9E%84&#34;&gt;定义和数据结构&lt;/a&gt;&lt;/li&gt;
